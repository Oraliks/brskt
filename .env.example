# ===========================
# DATABASE (Supabase)
# ===========================
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================
# AUTH (Better Auth + Telegram)
# ===========================
BETTER_AUTH_SECRET=                    # Generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
TELEGRAM_BOT_TOKEN=                    # From @BotFather
TELEGRAM_BOT_USERNAME=BoursikotonsBot

# Secret pour signer les magic-links (fallback /login via bot DM).
# Si vide, BETTER_AUTH_SECRET est utilisé. Generate: openssl rand -base64 32
MAGIC_LINK_SECRET=

# ===========================
# TELEGRAM VIP GROUP
# ===========================
VIP_GROUP_CHAT_ID=-100xxxxxxxxxx       # Negative ID of your VIP group
TELEGRAM_WEBHOOK_SECRET=               # Random string for webhook verification

# Canal Telegram (URL publique d'invitation ou username) — pour le LIEN
# affiché sur le dashboard user + footer
NEXT_PUBLIC_TELEGRAM_CHANNEL_URL=https://t.me/+xxxxxxxxxxxx

# Canal Telegram pour le COMPTEUR de membres affiché sur le dashboard
# et /admin. Le bot doit etre MEMBRE du canal (pas besoin d'etre admin).
# Choisir l'une des deux :
#   TELEGRAM_CHANNEL_ID=-1001234567890   (canal prive ou public, chat_id numerique)
#   TELEGRAM_CHANNEL_USERNAME=@moncanal  (canal public uniquement)
# Forward un message du canal vers @userinfobot pour obtenir le chat_id.
TELEGRAM_CHANNEL_ID=
TELEGRAM_CHANNEL_USERNAME=

# Channel/groupe d'alertes admin internes — reçoit les notifications quand
# une éjection auto a lieu (CRON quotidien). Optionnel : si vide, pas de
# notif. Créer un groupe privé avec ton bot + admins, et coller le chat_id
# (négatif pour un groupe, ex: -1001234567890).
ADMIN_ALERT_CHAT_ID=

# URL d'une vidéo "comment s'inscrire chez IronFX" (mp4 self-hosted ou
# embed YouTube). Affichée discrètement dans le wizard VIP, étape broker.
# Si vide : un texte fallback s'affiche à la place.
NEXT_PUBLIC_IRONFX_SIGNUP_VIDEO_URL=

# ===========================
# PAYMENTS — PADDLE
# ===========================
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=sandbox                     # sandbox | production
PADDLE_PRODUCT_ID_REMOTE=
PADDLE_PRODUCT_ID_ONSITE=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# ===========================
# PAYMENTS — PAYPAL
# ===========================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENV=sandbox                     # sandbox | live

# ===========================
# PAYMENTS — NOWPAYMENTS (CRYPTO)
# ===========================
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# ===========================
# IRONFX / IronAffiliates
# ===========================
# Le lien de base de ton compte affilié. On y append automatiquement
# ?sub_id=<ref> (ou & si query string déjà présent) pour tracker chaque
# user individuellement. Ex: https://track.affiliates.ironfx.com/visit/?bta=39880&nci=7160
IRONFX_AFFILIATE_BASE_LINK=
# Nom du param query où mettre notre ref dans le lien d'affiliation
# (par défaut: sub_id). Doit être supporté par IronAffiliates pour
# le retour dans les postbacks S2S.
IRONFX_AFFILIATE_SUBID_PARAM=sub_id

# Mode API (optionnel — on tourne en mode manuel par défaut)
IRONFX_API_URL=
IRONFX_API_KEY=
IRONFX_POSTBACK_SECRET=

# ===========================
# EMAIL (Resend)
# ===========================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@boursikotons.com
ADMIN_NOTIFICATION_EMAIL=admin@boursikotons.com

# ===========================
# ANALYTICS (PostHog)
# ===========================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=

# ===========================
# MONITORING (Sentry)
# ===========================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ===========================
# SECURITY
# ===========================
CRON_SECRET=                           # Generate: openssl rand -base64 32

# Whitelist d'admins par Telegram ID (défense en profondeur).
# Format: virgule-séparé, ex: ADMIN_TELEGRAM_IDS=6162961848,123456789
# Si vide en prod : warning loggé, accès admin via role DB seul (moins safe).
ADMIN_TELEGRAM_IDS=

# ===========================
# APP
# ===========================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Boursikotons"
