{
  "crons": [
    {
      "path": "/api/cron/check-vip-status",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/vip-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/daily-quiz",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/check-price-alerts",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/check-economic-alerts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/sync-economic-events",
      "schedule": "0 1 * * *"
    }
  ],
  "functions": {
    "src/app/api/webhooks/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    }
  }
}
